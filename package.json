{
  "name": "clawdoctor",
  "version": "0.1.0",
  "description": "Health diagnostics for OpenClaw agents",
  "type": "module",
  "bin": {
    "clawdoctor": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./plugin": "./dist/plugin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": ["openclaw", "diagnostics", "health", "agent", "ai", "lobster", "clawdoctor", "llm"],
  "homepage": "https://github.com/Lovelcp/clawdoctor",
  "repository": { "type": "git", "url": "https://github.com/Lovelcp/clawdoctor.git" },
  "bugs": { "url": "https://github.com/Lovelcp/clawdoctor/issues" },
  "files": ["dist/", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "hono": "^4.12.8",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
